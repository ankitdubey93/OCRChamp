# Copy this file to .env.docker and fill in your values.
# This file is loaded by compose.yaml via env_file.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ocrchamp
POSTGRES_PASSWORD=password
POSTGRES_DB=ocrchamp

# ── Notes ─────────────────────────────────────────────────────────────────────
# PG_HOST is set to 'db' (the Compose service name) directly in compose.yaml.
# You do NOT need to duplicate PG_HOST / PG_PORT / PG_DATABASE here because
# compose.yaml wires them from the POSTGRES_* vars above.
